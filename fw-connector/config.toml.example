# Copy this file to  config.toml  (next to the .exe) and fill in the real values.

# Your ShippingHub site
hub_url  = "https://freightwireship.com"

# Shared secret you generate in ShippingHub (Admin → API) for THIS connector.
# Treat it like a password. The connector sends it on every request (header x-fw-key).
hub_key  = "PASTE_THE_CONNECTOR_KEY_HERE"

# Full ODBC connection string for Full Circle (the ProvideX DSN Aptean gives you).
# Example forms:
#   odbc_conn = "DSN=FullCircle;UID=readonly;PWD=•••"
#   odbc_conn = "Driver={ProvideX ODBC Driver};Host=fcserver;Port=20222;Database=LAGENCE;UID=...;PWD=..."
odbc_conn = "DSN=FullCircle;UID=readonly;PWD=CHANGE_ME"

# The Full Circle table the orders live in (default matches the Ship Manager profile).
table = "asups_UPS_Interface"

# Where the ship-confirmation file drops for Full Circle to ingest.
drop_path = "Z:\\ups\\fedxucc.csv"

# How often to poll ShippingHub, in milliseconds.
poll_ms = 4000
